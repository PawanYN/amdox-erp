// ============================================================================
// AMDOX ERP — Inferred Prisma Schema (full draft)
// ============================================================================
// NOTE: Field names/types are inferred conventions based on the project PDF
// (AMX-ERP-2026-04) and standard ERP practice. Cross-check every model
// against your real schema.prisma and correct field names, types, and
// relations as needed — this is a starting point, not the source of truth.
//
// Conventions applied throughout:
//   - Every tenant-scoped model has tenantId + relation to Tenant
//   - createdAt / updatedAt on every model
//   - deletedAt on every model that supports soft-delete
//   - Money fields use Decimal(18,4)
//   - Enums used for fixed-choice fields
// ============================================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================================================
// ENUMS
// ============================================================================

enum TenantPlan {
  FREE
  STANDARD
  ENTERPRISE
}

enum SystemRole {
  SUPER_ADMIN
  TENANT_ADMIN
  MANAGER
  VIEWER
}

enum AccountType {
  ASSET
  LIABILITY
  EQUITY
  REVENUE
  EXPENSE
}

enum JournalEntryStatus {
  DRAFT
  POSTED
  REVERSED
}

enum InvoiceType {
  AP
  AR
}

enum InvoiceStatus {
  DRAFT
  PENDING_MATCH
  MATCHED
  APPROVED
  PAID
  OVERDUE
  CANCELLED
}

enum PaymentStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
}

enum EmploymentStatus {
  ACTIVE
  ON_LEAVE
  SUSPENDED
  TERMINATED
}

enum LeaveStatus {
  PENDING
  APPROVED
  REJECTED
  CANCELLED
}

enum PayrollRunStatus {
  SCHEDULED
  PROCESSING
  COMPLETED
  FAILED
  COMPENSATING
}

enum PurchaseOrderStatus {
  DRAFT
  SUBMITTED
  APPROVED
  PARTIALLY_RECEIVED
  RECEIVED
  CLOSED
  CANCELLED
}

enum StockMovementType {
  RECEIPT
  ISSUE
  ADJUSTMENT
  TRANSFER
  RETURN
}

enum ForecastModelType {
  PROPHET
  LSTM
}

enum ProjectStatus {
  PLANNING
  ACTIVE
  ON_HOLD
  COMPLETED
  CANCELLED
}

enum TaskStatus {
  TODO
  IN_PROGRESS
  BLOCKED
  DONE
}

enum NotificationChannel {
  IN_APP
  EMAIL
  SMS
  WEBHOOK
}

enum NotificationDeliveryStatus {
  PENDING
  SENT
  FAILED
  RETRYING
}

enum OutboxEventStatus {
  PENDING
  PROCESSING
  PROCESSED
  FAILED
}

enum DataSubjectRequestType {
  ACCESS
  ERASURE
  PORTABILITY
}

enum DataSubjectRequestStatus {
  OPEN
  IN_PROGRESS
  FULFILLED
  REJECTED
}

// ============================================================================
// 1. TENANCY & AUTH (F-01)
// ============================================================================

model Tenant {
  id        String     @id @default(uuid())
  name      String
  slug      String     @unique
  plan      TenantPlan @default(STANDARD)
  settings  Json?
  isActive  Boolean    @default(true)
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  deletedAt DateTime?

  users           User[]
  roles           Role[]
  userRoles       UserRole[]
  permissions     Permission[]
  refreshTokens   RefreshToken[]

  accounts        Account[]
  journalEntries  JournalEntry[]
  journalLines    JournalLine[]
  fiscalPeriods   FiscalPeriod[]
  currencies      Currency[]
  exchangeRates   ExchangeRate[]
  invoices        Invoice[]
  invoiceLines    InvoiceLine[]
  payments        Payment[]
  paymentRuns     PaymentRun[]
  customers       Customer[]
  intercompanyTransfers IntercompanyTransfer[]

  employees       Employee[]
  departments     Department[]
  employmentContracts EmploymentContract[]
  leaveTypes      LeaveType[]
  leaveRequests   LeaveRequest[]
  leaveBalances   LeaveBalance[]
  attendanceRecords AttendanceRecord[]
  payrollRuns     PayrollRun[]
  payslips        Payslip[]

  vendors         Vendor[]
  warehouses      Warehouse[]
  products        Product[]
  purchaseRequisitions PurchaseRequisition[]
  purchaseOrders  PurchaseOrder[]
  purchaseOrderLines PurchaseOrderLine[]
  goodsReceipts   GoodsReceipt[]
  stockLevels     StockLevel[]
  stockMovements  StockMovement[]
  reorderRules    ReorderRule[]

  forecastModels  ForecastModel[]
  forecastPredictions ForecastPrediction[]

  projects        Project[]
  tasks           Task[]
  milestones      Milestone[]
  resourceAllocations ResourceAllocation[]
  projectBudgets  ProjectBudget[]
  projectBudgetLines ProjectBudgetLine[]

  dashboards      Dashboard[]
  widgets         Widget[]
  scheduledReports ScheduledReport[]

  notifications   Notification[]
  notificationPreferences NotificationPreference[]
  notificationDeliveries NotificationDelivery[]

  webhookSubscriptions WebhookSubscription[]
  webhookDeliveries WebhookDelivery[]
  apiKeys         ApiKey[]

  auditLogs       AuditLog[]
  dataSubjectRequests DataSubjectRequest[]
  consentRecords  ConsentRecord[]

  outboxEvents    OutboxEvent[]

  @@index([slug])
}

model User {
  id           String    @id @default(uuid())
  tenantId     String
  tenant       Tenant    @relation(fields: [tenantId], references: [id])
  email        String
  fullName     String
  passwordHash String?
  ssoSubject   String?
  isActive     Boolean   @default(true)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  deletedAt    DateTime?

  userRoles      UserRole[]
  refreshTokens  RefreshToken[]
  auditLogs      AuditLog[]
  leaveRequests  LeaveRequest[] @relation("LeaveRequestedBy")
  notifications  Notification[]
  notifPreferences NotificationPreference[]
  apiKeys        ApiKey[]

  @@unique([tenantId, email])
  @@index([tenantId])
}

model Role {
  id          String   @id @default(uuid())
  tenantId    String
  tenant      Tenant   @relation(fields: [tenantId], references: [id])
  name        String
  systemRole  SystemRole @default(VIEWER)
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  userRoles       UserRole[]
  rolePermissions RolePermission[]

  @@unique([tenantId, name])
  @@index([tenantId])
}

model UserRole {
  id        String   @id @default(uuid())
  tenantId  String
  tenant    Tenant   @relation(fields: [tenantId], references: [id])
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  roleId    String
  role      Role     @relation(fields: [roleId], references: [id])
  createdAt DateTime @default(now())

  @@unique([userId, roleId])
  @@index([tenantId])
}

model Permission {
  id          String   @id @default(uuid())
  tenantId    String
  tenant      Tenant   @relation(fields: [tenantId], references: [id])
  key         String   // e.g. "finance.invoice.approve"
  description String?

  rolePermissions RolePermission[]

  @@unique([tenantId, key])
  @@index([tenantId])
}

model RolePermission {
  id           String     @id @default(uuid())
  roleId       String
  role         Role       @relation(fields: [roleId], references: [id])
  permissionId String
  permission   Permission @relation(fields: [permissionId], references: [id])

  @@unique([roleId, permissionId])
}

model RefreshToken {
  id          String    @id @default(uuid())
  tenantId    String
  tenant      Tenant    @relation(fields: [tenantId], references: [id])
  userId      String
  user        User      @relation(fields: [userId], references: [id])
  tokenHash   String    @unique
  isRevoked   Boolean   @default(false)
  expiresAt   DateTime
  createdAt   DateTime  @default(now())

  @@index([tenantId])
  @@index([userId])
}

// ============================================================================
// 2. FINANCE — GL / AP / AR (F-02, F-03)
// ============================================================================

model Account {
  id          String      @id @default(uuid())
  tenantId    String
  tenant      Tenant      @relation(fields: [tenantId], references: [id])
  code        String
  name        String
  type        AccountType
  parentId    String?
  parent      Account?    @relation("AccountHierarchy", fields: [parentId], references: [id])
  children    Account[]   @relation("AccountHierarchy")
  currencyId  String?
  currency    Currency?   @relation(fields: [currencyId], references: [id])
  isActive    Boolean     @default(true)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  deletedAt   DateTime?

  journalLines JournalLine[]

  @@unique([tenantId, code])
  @@index([tenantId])
}

model FiscalPeriod {
  id        String   @id @default(uuid())
  tenantId  String
  tenant    Tenant   @relation(fields: [tenantId], references: [id])
  name      String   // e.g. "2026-06"
  startDate DateTime
  endDate   DateTime
  isLocked  Boolean  @default(false)
  lockedAt  DateTime?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  journalEntries JournalEntry[]

  @@unique([tenantId, name])
  @@index([tenantId])
}

model JournalEntry {
  id             String             @id @default(uuid())
  tenantId       String
  tenant         Tenant             @relation(fields: [tenantId], references: [id])
  fiscalPeriodId String
  fiscalPeriod   FiscalPeriod       @relation(fields: [fiscalPeriodId], references: [id])
  reference      String
  description    String?
  status         JournalEntryStatus @default(DRAFT)
  postedAt       DateTime?
  sourceModule   String?            // e.g. "AP", "PAYROLL", "AR"
  sourceId       String?            // polymorphic ref to originating record
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt
  deletedAt      DateTime?

  lines JournalLine[]

  @@index([tenantId])
  @@index([fiscalPeriodId])
}

model JournalLine {
  id             String       @id @default(uuid())
  tenantId       String
  tenant         Tenant       @relation(fields: [tenantId], references: [id])
  journalEntryId String
  journalEntry   JournalEntry @relation(fields: [journalEntryId], references: [id])
  accountId      String
  account        Account      @relation(fields: [accountId], references: [id])
  debit          Decimal      @default(0) @db.Decimal(18, 4)
  credit         Decimal      @default(0) @db.Decimal(18, 4)
  currencyId     String?
  currency       Currency?    @relation(fields: [currencyId], references: [id])
  fxRate         Decimal?     @db.Decimal(18, 6)
  createdAt      DateTime     @default(now())

  @@index([tenantId])
  @@index([journalEntryId])
  @@index([accountId])
}

model Currency {
  id        String   @id @default(uuid())
  tenantId  String
  tenant    Tenant   @relation(fields: [tenantId], references: [id])
  code      String   // ISO 4217, e.g. "USD"
  symbol    String?
  isBase    Boolean  @default(false)

  accounts      Account[]
  journalLines  JournalLine[]
  exchangeRatesFrom ExchangeRate[] @relation("FromCurrency")
  exchangeRatesTo   ExchangeRate[] @relation("ToCurrency")
  invoices      Invoice[]

  @@unique([tenantId, code])
  @@index([tenantId])
}

model ExchangeRate {
  id             String   @id @default(uuid())
  tenantId       String
  tenant         Tenant   @relation(fields: [tenantId], references: [id])
  fromCurrencyId String
  fromCurrency   Currency @relation("FromCurrency", fields: [fromCurrencyId], references: [id])
  toCurrencyId   String
  toCurrency     Currency @relation("ToCurrency", fields: [toCurrencyId], references: [id])
  rate           Decimal  @db.Decimal(18, 6)
  asOfDate       DateTime
  source         String?  // e.g. "ECB", "OpenExchangeRates"
  createdAt      DateTime @default(now())

  @@unique([tenantId, fromCurrencyId, toCurrencyId, asOfDate])
  @@index([tenantId])
}

model IntercompanyTransfer {
  id            String   @id @default(uuid())
  tenantId      String
  tenant        Tenant   @relation(fields: [tenantId], references: [id])
  fromAccountId String
  toAccountId   String
  amount        Decimal  @db.Decimal(18, 4)
  description   String?
  createdAt     DateTime @default(now())

  @@index([tenantId])
}

model Customer {
  id        String   @id @default(uuid())
  tenantId  String
  tenant    Tenant   @relation(fields: [tenantId], references: [id])
  name      String
  email     String?
  billingAddress Json?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  deletedAt DateTime?

  invoices Invoice[]

  @@index([tenantId])
}

model Invoice {
  id              String        @id @default(uuid())
  tenantId        String
  tenant          Tenant        @relation(fields: [tenantId], references: [id])
  type            InvoiceType   // AP or AR
  invoiceNumber   String
  vendorId        String?
  vendor          Vendor?       @relation(fields: [vendorId], references: [id])
  customerId      String?
  customer        Customer?     @relation(fields: [customerId], references: [id])
  purchaseOrderId String?
  purchaseOrder   PurchaseOrder? @relation(fields: [purchaseOrderId], references: [id])
  currencyId      String?
  currency        Currency?     @relation(fields: [currencyId], references: [id])
  status          InvoiceStatus @default(DRAFT)
  ocrConfidence   Float?
  issueDate       DateTime
  dueDate         DateTime
  totalAmount     Decimal       @db.Decimal(18, 4)
  matchedAt       DateTime?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  deletedAt       DateTime?

  lines    InvoiceLine[]
  payments Payment[]

  @@unique([tenantId, invoiceNumber])
  @@index([tenantId])
  @@index([vendorId])
  @@index([customerId])
}

model InvoiceLine {
  id          String   @id @default(uuid())
  tenantId    String
  tenant      Tenant   @relation(fields: [tenantId], references: [id])
  invoiceId   String
  invoice     Invoice  @relation(fields: [invoiceId], references: [id])
  description String
  quantity    Decimal  @db.Decimal(18, 4)
  unitPrice   Decimal  @db.Decimal(18, 4)
  lineTotal   Decimal  @db.Decimal(18, 4)

  @@index([tenantId])
  @@index([invoiceId])
}

model Payment {
  id            String        @id @default(uuid())
  tenantId      String
  tenant        Tenant        @relation(fields: [tenantId], references: [id])
  invoiceId     String
  invoice       Invoice       @relation(fields: [invoiceId], references: [id])
  paymentRunId  String?
  paymentRun    PaymentRun?   @relation(fields: [paymentRunId], references: [id])
  amount        Decimal       @db.Decimal(18, 4)
  status        PaymentStatus @default(PENDING)
  paidAt        DateTime?
  createdAt     DateTime      @default(now())

  @@index([tenantId])
  @@index([invoiceId])
}

model PaymentRun {
  id          String   @id @default(uuid())
  tenantId    String
  tenant      Tenant   @relation(fields: [tenantId], references: [id])
  runDate     DateTime
  description String?
  createdAt   DateTime @default(now())

  payments Payment[]

  @@index([tenantId])
}

// ============================================================================
// 3. HR & PAYROLL (F-04)
// ============================================================================

model Department {
  id        String   @id @default(uuid())
  tenantId  String
  tenant    Tenant   @relation(fields: [tenantId], references: [id])
  name      String
  parentId  String?
  parent    Department? @relation("DeptHierarchy", fields: [parentId], references: [id])
  children  Department[] @relation("DeptHierarchy")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  deletedAt DateTime?

  employees Employee[]

  @@unique([tenantId, name])
  @@index([tenantId])
}

model Employee {
  id               String           @id @default(uuid())
  tenantId         String
  tenant           Tenant           @relation(fields: [tenantId], references: [id])
  userId           String?
  fullName         String
  email            String
  departmentId     String?
  department       Department?      @relation(fields: [departmentId], references: [id])
  managerId        String?
  manager          Employee?        @relation("ReportingHierarchy", fields: [managerId], references: [id])
  directReports    Employee[]       @relation("ReportingHierarchy")
  status           EmploymentStatus @default(ACTIVE)
  hireDate         DateTime
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt
  deletedAt        DateTime?

  contracts          EmploymentContract[]
  leaveRequests       LeaveRequest[]
  leaveBalances       LeaveBalance[]
  attendanceRecords   AttendanceRecord[]
  payslips            Payslip[]
  resourceAllocations ResourceAllocation[]

  @@unique([tenantId, email])
  @@index([tenantId])
  @@index([departmentId])
}

model EmploymentContract {
  id          String   @id @default(uuid())
  tenantId    String
  tenant      Tenant   @relation(fields: [tenantId], references: [id])
  employeeId  String
  employee    Employee @relation(fields: [employeeId], references: [id])
  jobTitle    String
  salary      Decimal  @db.Decimal(18, 4)
  currencyCode String  @default("USD")
  startDate   DateTime
  endDate     DateTime?
  createdAt   DateTime @default(now())

  @@index([tenantId])
  @@index([employeeId])
}

model LeaveType {
  id           String  @id @default(uuid())
  tenantId     String
  tenant       Tenant  @relation(fields: [tenantId], references: [id])
  name         String  // e.g. "Annual", "Sick"
  accrualRate  Decimal @default(0) @db.Decimal(10, 4) // days per month

  leaveRequests LeaveRequest[]
  leaveBalances LeaveBalance[]

  @@unique([tenantId, name])
  @@index([tenantId])
}

model LeaveRequest {
  id            String      @id @default(uuid())
  tenantId      String
  tenant        Tenant      @relation(fields: [tenantId], references: [id])
  employeeId    String
  employee      Employee    @relation(fields: [employeeId], references: [id])
  leaveTypeId   String
  leaveType     LeaveType   @relation(fields: [leaveTypeId], references: [id])
  startDate     DateTime
  endDate       DateTime
  status        LeaveStatus @default(PENDING)
  requestedById String?
  requestedBy   User?       @relation("LeaveRequestedBy", fields: [requestedById], references: [id])
  approvedAt    DateTime?
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  @@index([tenantId])
  @@index([employeeId])
}

model LeaveBalance {
  id          String    @id @default(uuid())
  tenantId    String
  tenant      Tenant    @relation(fields: [tenantId], references: [id])
  employeeId  String
  employee    Employee  @relation(fields: [employeeId], references: [id])
  leaveTypeId String
  leaveType   LeaveType @relation(fields: [leaveTypeId], references: [id])
  balanceDays Decimal   @default(0) @db.Decimal(10, 4)
  updatedAt   DateTime  @updatedAt

  @@unique([employeeId, leaveTypeId])
  @@index([tenantId])
}

model AttendanceRecord {
  id          String   @id @default(uuid())
  tenantId    String
  tenant      Tenant   @relation(fields: [tenantId], references: [id])
  employeeId  String
  employee    Employee @relation(fields: [employeeId], references: [id])
  clockIn     DateTime
  clockOut    DateTime?
  overtimeMins Int     @default(0)
  createdAt   DateTime @default(now())

  @@index([tenantId])
  @@index([employeeId])
}

model PayrollRun {
  id          String           @id @default(uuid())
  tenantId    String
  tenant      Tenant           @relation(fields: [tenantId], references: [id])
  periodLabel String           // e.g. "2026-06"
  status      PayrollRunStatus @default(SCHEDULED)
  totalNetPay Decimal?         @db.Decimal(18, 4)
  startedAt   DateTime?
  completedAt DateTime?
  createdAt   DateTime         @default(now())

  payslips   Payslip[]
  sagaSteps  SagaState[]

  @@index([tenantId])
}

model Payslip {
  id           String     @id @default(uuid())
  tenantId     String
  tenant       Tenant     @relation(fields: [tenantId], references: [id])
  payrollRunId String
  payrollRun   PayrollRun @relation(fields: [payrollRunId], references: [id])
  employeeId   String
  employee     Employee   @relation(fields: [employeeId], references: [id])
  grossPay     Decimal    @db.Decimal(18, 4)
  deductions   Decimal    @db.Decimal(18, 4)
  netPay       Decimal    @db.Decimal(18, 4)
  pdfUrl       String?
  createdAt    DateTime   @default(now())

  @@index([tenantId])
  @@index([payrollRunId])
  @@index([employeeId])
}

// ============================================================================
// 4. SUPPLY CHAIN & INVENTORY (F-05) + AI FORECASTING (F-06)
// ============================================================================

model Vendor {
  id        String   @id @default(uuid())
  tenantId  String
  tenant    Tenant   @relation(fields: [tenantId], references: [id])
  name      String
  email     String?
  webhookUrl String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  deletedAt DateTime?

  purchaseOrders PurchaseOrder[]
  invoices       Invoice[]

  @@index([tenantId])
}

model Warehouse {
  id        String   @id @default(uuid())
  tenantId  String
  tenant    Tenant   @relation(fields: [tenantId], references: [id])
  name      String
  location  String?
  createdAt DateTime @default(now())

  stockLevels    StockLevel[]
  stockMovements StockMovement[]

  @@index([tenantId])
}

model Product {
  id        String   @id @default(uuid())
  tenantId  String
  tenant    Tenant   @relation(fields: [tenantId], references: [id])
  sku       String
  name      String
  unitCost  Decimal  @default(0) @db.Decimal(18, 4)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  deletedAt DateTime?

  stockLevels         StockLevel[]
  stockMovements      StockMovement[]
  reorderRules        ReorderRule[]
  purchaseOrderLines  PurchaseOrderLine[]
  forecastPredictions ForecastPrediction[]

  @@unique([tenantId, sku])
  @@index([tenantId])
}

model PurchaseRequisition {
  id          String   @id @default(uuid())
  tenantId    String
  tenant      Tenant   @relation(fields: [tenantId], references: [id])
  requestedBy String?
  reason      String?
  createdAt   DateTime @default(now())

  purchaseOrders PurchaseOrder[]

  @@index([tenantId])
}

model PurchaseOrder {
  id              String              @id @default(uuid())
  tenantId        String
  tenant          Tenant              @relation(fields: [tenantId], references: [id])
  poNumber        String
  vendorId        String
  vendor          Vendor              @relation(fields: [vendorId], references: [id])
  requisitionId   String?
  requisition     PurchaseRequisition? @relation(fields: [requisitionId], references: [id])
  status          PurchaseOrderStatus @default(DRAFT)
  totalAmount     Decimal             @db.Decimal(18, 4)
  orderedAt       DateTime?
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt
  deletedAt       DateTime?

  lines         PurchaseOrderLine[]
  goodsReceipts GoodsReceipt[]
  invoices      Invoice[]

  @@unique([tenantId, poNumber])
  @@index([tenantId])
  @@index([vendorId])
}

model PurchaseOrderLine {
  id              String        @id @default(uuid())
  tenantId        String
  tenant          Tenant        @relation(fields: [tenantId], references: [id])
  purchaseOrderId String
  purchaseOrder   PurchaseOrder @relation(fields: [purchaseOrderId], references: [id])
  productId       String
  product         Product       @relation(fields: [productId], references: [id])
  quantity        Decimal       @db.Decimal(18, 4)
  unitPrice       Decimal       @db.Decimal(18, 4)

  @@index([tenantId])
  @@index([purchaseOrderId])
}

model GoodsReceipt {
  id              String        @id @default(uuid())
  tenantId        String
  tenant          Tenant        @relation(fields: [tenantId], references: [id])
  purchaseOrderId String
  purchaseOrder   PurchaseOrder @relation(fields: [purchaseOrderId], references: [id])
  receivedAt      DateTime      @default(now())
  notes           String?

  @@index([tenantId])
  @@index([purchaseOrderId])
}

model StockLevel {
  id          String    @id @default(uuid())
  tenantId    String
  tenant      Tenant    @relation(fields: [tenantId], references: [id])
  productId   String
  product     Product   @relation(fields: [productId], references: [id])
  warehouseId String
  warehouse   Warehouse @relation(fields: [warehouseId], references: [id])
  quantity    Decimal   @default(0) @db.Decimal(18, 4)
  updatedAt   DateTime  @updatedAt

  @@unique([productId, warehouseId])
  @@index([tenantId])
}

model StockMovement {
  id          String            @id @default(uuid())
  tenantId    String
  tenant      Tenant            @relation(fields: [tenantId], references: [id])
  productId   String
  product     Product           @relation(fields: [productId], references: [id])
  warehouseId String
  warehouse   Warehouse         @relation(fields: [warehouseId], references: [id])
  type        StockMovementType
  quantity    Decimal           @db.Decimal(18, 4)
  reference   String?           // e.g. GoodsReceipt id, SalesOrder id
  createdAt   DateTime          @default(now())

  @@index([tenantId])
  @@index([productId])
}

model ReorderRule {
  id          String   @id @default(uuid())
  tenantId    String
  tenant      Tenant   @relation(fields: [tenantId], references: [id])
  productId   String
  product     Product  @relation(fields: [productId], references: [id])
  thresholdQty Decimal @db.Decimal(18, 4)
  reorderQty   Decimal @db.Decimal(18, 4)
  isActive     Boolean @default(true)

  @@index([tenantId])
  @@index([productId])
}

model ForecastModel {
  id          String            @id @default(uuid())
  tenantId    String
  tenant      Tenant            @relation(fields: [tenantId], references: [id])
  type        ForecastModelType
  version     String
  trainedAt   DateTime?
  mapeScore   Float?
  isActive    Boolean           @default(false)
  createdAt   DateTime          @default(now())

  predictions ForecastPrediction[]

  @@index([tenantId])
}

model ForecastPrediction {
  id              String        @id @default(uuid())
  tenantId        String
  tenant          Tenant        @relation(fields: [tenantId], references: [id])
  forecastModelId String
  forecastModel   ForecastModel @relation(fields: [forecastModelId], references: [id])
  productId       String
  product         Product       @relation(fields: [productId], references: [id])
  forecastDate    DateTime
  predictedQty    Decimal       @db.Decimal(18, 4)
  createdAt       DateTime      @default(now())

  @@index([tenantId])
  @@index([productId])
}

// ============================================================================
// 5. PROJECT MANAGEMENT (F-07)
// ============================================================================

model Project {
  id          String        @id @default(uuid())
  tenantId    String
  tenant      Tenant        @relation(fields: [tenantId], references: [id])
  name        String
  description String?
  status      ProjectStatus @default(PLANNING)
  startDate   DateTime?
  endDate     DateTime?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  deletedAt   DateTime?

  tasks               Task[]
  milestones          Milestone[]
  resourceAllocations ResourceAllocation[]
  budgets             ProjectBudget[]

  @@index([tenantId])
}

model Task {
  id          String     @id @default(uuid())
  tenantId    String
  tenant      Tenant     @relation(fields: [tenantId], references: [id])
  projectId   String
  project     Project    @relation(fields: [projectId], references: [id])
  milestoneId String?
  milestone   Milestone? @relation(fields: [milestoneId], references: [id])
  title       String
  status      TaskStatus @default(TODO)
  startDate   DateTime?
  dueDate     DateTime?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  dependsOn   TaskDependency[] @relation("DependentTask")
  dependedBy  TaskDependency[] @relation("PrerequisiteTask")
  allocations ResourceAllocation[]

  @@index([tenantId])
  @@index([projectId])
}

model TaskDependency {
  id               String @id @default(uuid())
  tenantId         String
  dependentTaskId  String
  dependentTask    Task   @relation("DependentTask", fields: [dependentTaskId], references: [id])
  prerequisiteTaskId String
  prerequisiteTask Task   @relation("PrerequisiteTask", fields: [prerequisiteTaskId], references: [id])

  @@unique([dependentTaskId, prerequisiteTaskId])
  @@index([tenantId])
}

model Milestone {
  id        String   @id @default(uuid())
  tenantId  String
  tenant    Tenant   @relation(fields: [tenantId], references: [id])
  projectId String
  project   Project  @relation(fields: [projectId], references: [id])
  name      String
  dueDate   DateTime
  isAchieved Boolean @default(false)
  createdAt DateTime @default(now())

  tasks Task[]

  @@index([tenantId])
  @@index([projectId])
}

model ResourceAllocation {
  id          String   @id @default(uuid())
  tenantId    String
  tenant      Tenant   @relation(fields: [tenantId], references: [id])
  projectId   String
  project     Project  @relation(fields: [projectId], references: [id])
  taskId      String?
  task        Task?    @relation(fields: [taskId], references: [id])
  employeeId  String
  employee    Employee @relation(fields: [employeeId], references: [id])
  allocatedHours Decimal @db.Decimal(10, 2)
  startDate   DateTime
  endDate     DateTime?

  @@index([tenantId])
  @@index([projectId])
  @@index([employeeId])
}

model ProjectBudget {
  id            String   @id @default(uuid())
  tenantId      String
  tenant        Tenant   @relation(fields: [tenantId], references: [id])
  projectId     String
  project       Project  @relation(fields: [projectId], references: [id])
  plannedAmount Decimal  @db.Decimal(18, 4)
  actualAmount  Decimal  @default(0) @db.Decimal(18, 4)
  overrunThresholdPct Decimal @default(10) @db.Decimal(5, 2)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  lines ProjectBudgetLine[]

  @@index([tenantId])
  @@index([projectId])
}

model ProjectBudgetLine {
  id              String        @id @default(uuid())
  tenantId        String
  tenant          Tenant        @relation(fields: [tenantId], references: [id])
  projectBudgetId String
  projectBudget   ProjectBudget @relation(fields: [projectBudgetId], references: [id])
  description     String
  amount          Decimal       @db.Decimal(18, 4)
  journalEntryRef String?       // link back to Finance GL posting

  @@index([tenantId])
  @@index([projectBudgetId])
}

// ============================================================================
// 6. BUSINESS INTELLIGENCE (F-08)
// ============================================================================

model Dashboard {
  id        String   @id @default(uuid())
  tenantId  String
  tenant    Tenant   @relation(fields: [tenantId], references: [id])
  name      String
  ownerId   String?
  layout    Json?    // widget positions
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  deletedAt DateTime?

  widgets Widget[]

  @@index([tenantId])
}

model Widget {
  id          String   @id @default(uuid())
  tenantId    String
  tenant      Tenant   @relation(fields: [tenantId], references: [id])
  dashboardId String
  dashboard   Dashboard @relation(fields: [dashboardId], references: [id])
  type        String   // "bar" | "line" | "pie" | "heatmap" | "funnel"
  config      Json      // chart config, source query, filters
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([tenantId])
  @@index([dashboardId])
}

model ScheduledReport {
  id           String   @id @default(uuid())
  tenantId     String
  tenant       Tenant   @relation(fields: [tenantId], references: [id])
  name         String
  cronExpr     String
  format       String   // "PDF" | "EXCEL"
  recipients   String[]
  lastRunAt    DateTime?
  createdAt    DateTime @default(now())

  @@index([tenantId])
}

// ============================================================================
// 7. NOTIFICATION ENGINE (F-10)
// ============================================================================

model Notification {
  id        String   @id @default(uuid())
  tenantId  String
  tenant    Tenant   @relation(fields: [tenantId], references: [id])
  userId    String?
  user      User?    @relation(fields: [userId], references: [id])
  eventType String   // e.g. "PO_CREATED", "BUDGET_OVERRUN"
  title     String
  body      String?
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())

  deliveries NotificationDelivery[]

  @@index([tenantId])
  @@index([userId])
}

model NotificationPreference {
  id        String              @id @default(uuid())
  tenantId  String
  tenant    Tenant              @relation(fields: [tenantId], references: [id])
  userId    String
  user      User                @relation(fields: [userId], references: [id])
  eventType String
  channel   NotificationChannel
  isEnabled Boolean             @default(true)

  @@unique([userId, eventType, channel])
  @@index([tenantId])
}

model NotificationDelivery {
  id             String                     @id @default(uuid())
  tenantId       String
  tenant         Tenant                     @relation(fields: [tenantId], references: [id])
  notificationId String
  notification   Notification               @relation(fields: [notificationId], references: [id])
  channel        NotificationChannel
  status         NotificationDeliveryStatus @default(PENDING)
  attempts       Int                        @default(0)
  lastError      String?
  sentAt         DateTime?

  @@index([tenantId])
  @@index([notificationId])
}

// ============================================================================
// 8. API GATEWAY & WEBHOOKS (F-11)
// ============================================================================

model WebhookSubscription {
  id          String   @id @default(uuid())
  tenantId    String
  tenant      Tenant   @relation(fields: [tenantId], references: [id])
  url         String
  eventTypes  String[]
  secret      String   // HMAC signing secret
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())

  deliveries WebhookDelivery[]

  @@index([tenantId])
}

model WebhookDelivery {
  id             String               @id @default(uuid())
  tenantId       String
  tenant         Tenant               @relation(fields: [tenantId], references: [id])
  subscriptionId String
  subscription   WebhookSubscription  @relation(fields: [subscriptionId], references: [id])
  eventType      String
  payload        Json
  statusCode     Int?
  attempts       Int                  @default(0)
  deliveredAt    DateTime?
  createdAt      DateTime             @default(now())

  @@index([tenantId])
  @@index([subscriptionId])
}

model ApiKey {
  id         String   @id @default(uuid())
  tenantId   String
  tenant     Tenant   @relation(fields: [tenantId], references: [id])
  userId     String?
  user       User?    @relation(fields: [userId], references: [id])
  keyHash    String   @unique
  label      String?
  lastUsedAt DateTime?
  expiresAt  DateTime?
  createdAt  DateTime @default(now())

  @@index([tenantId])
}

// ============================================================================
// 9. AUDIT & COMPLIANCE (F-09)
// ============================================================================

model AuditLog {
  id          String   @id @default(uuid())
  tenantId    String
  tenant      Tenant   @relation(fields: [tenantId], references: [id])
  userId      String?
  user        User?    @relation(fields: [userId], references: [id])
  action      String   // e.g. "INVOICE_APPROVED"
  entityType  String   // e.g. "Invoice"
  entityId    String
  beforeState Json?
  afterState  Json?
  hash        String   // tamper-evident hash chain
  previousHash String?
  createdAt   DateTime @default(now())

  @@index([tenantId])
  @@index([entityType, entityId])
}

model DataSubjectRequest {
  id          String                   @id @default(uuid())
  tenantId    String
  tenant      Tenant                   @relation(fields: [tenantId], references: [id])
  subjectEmail String
  type        DataSubjectRequestType
  status      DataSubjectRequestStatus @default(OPEN)
  requestedAt DateTime                 @default(now())
  fulfilledAt DateTime?

  @@index([tenantId])
}

model ConsentRecord {
  id          String   @id @default(uuid())
  tenantId    String
  tenant      Tenant   @relation(fields: [tenantId], references: [id])
  subjectEmail String
  consentType String
  granted     Boolean
  recordedAt  DateTime @default(now())

  @@index([tenantId])
}

// ============================================================================
// 10. CROSS-CUTTING: OUTBOX PATTERN & SAGA STATE
// ============================================================================

model OutboxEvent {
  id          String            @id @default(uuid())
  tenantId    String
  tenant      Tenant            @relation(fields: [tenantId], references: [id])
  eventType   String            // e.g. "PO_CREATED", "PAYROLL_COMPLETED"
  payload     Json
  status      OutboxEventStatus @default(PENDING)
  attempts    Int               @default(0)
  processedAt DateTime?
  createdAt   DateTime          @default(now())

  @@index([tenantId])
  @@index([status])
}

model SagaState {
  id           String     @id @default(uuid())
  payrollRunId String
  payrollRun   PayrollRun @relation(fields: [payrollRunId], references: [id])
  stepName     String     // e.g. "CALCULATE_GROSS", "POST_GL", "GENERATE_PAYSLIP"
  status       String     // "PENDING" | "DONE" | "COMPENSATED" | "FAILED"
  payload      Json?
  executedAt   DateTime?

  @@index([payrollRunId])
}
